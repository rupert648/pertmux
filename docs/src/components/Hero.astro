---
---
<section class="relative overflow-hidden pt-24 pb-12 sm:pt-32 sm:pb-16">
  <!-- Background effects -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-orange-900/20 via-gray-950 to-gray-950"></div>
  <div class="absolute top-0 left-1/2 -z-10 -translate-x-1/2 blur-3xl xl:-top-6" aria-hidden="true">
    <div class="aspect-[1155/678] w-[72.1875rem] bg-gradient-to-tr from-[#ff8c00] to-[#ffbd6b] opacity-10" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl lg:text-7xl">
      <span class="block">Your MRs. Your worktrees. Your agents.</span>
      <span class="block text-orange-400 mt-2">One dashboard.</span>
    </h1>
    
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-300 sm:text-xl">
      A Rust TUI that links GitLab/GitHub merge requests to local branches, tmux sessions, and AI coding agents — so you never lose context.
    </p>
    
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
      <div class="group relative flex items-center justify-between gap-4 rounded-lg bg-gray-900 border border-gray-700 px-6 py-3 shadow-[0_0_20px_rgba(255,140,0,0.15)] transition-all hover:border-orange-400 hover:shadow-[0_0_30px_rgba(255,140,0,0.3)]">
        <code class="font-mono text-sm text-orange-400">cargo install pertmux</code>
        <button class="text-gray-400 hover:text-white transition-colors" aria-label="Copy install command" onclick="navigator.clipboard.writeText('cargo install pertmux')">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
      
      <a href="/getting-started/installation/" class="text-base font-semibold leading-7 text-white hover:text-orange-400 transition-colors flex items-center gap-2">
        Read the docs <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="mt-12 sm:mt-16 flex justify-center">
      <div class="relative w-full max-w-[900px] aspect-video rounded-xl border border-gray-800 bg-gray-900/50 shadow-[0_0_40px_rgba(255,140,0,0.1)] flex items-center justify-center overflow-hidden backdrop-blur-sm">
        <!-- Window controls decoration -->
        <div class="absolute top-0 left-0 w-full h-10 border-b border-gray-800 bg-gray-900/80 flex items-center px-4 gap-2">
          <div class="w-3 h-3 rounded-full bg-gray-700"></div>
          <div class="w-3 h-3 rounded-full bg-gray-700"></div>
          <div class="w-3 h-3 rounded-full bg-gray-700"></div>
        </div>
        
        <p class="text-gray-500 italic font-mono text-sm sm:text-base mt-10">
          [ Screenshot / GIF of pertmux TUI ]
        </p>
      </div>
    </div>
  </div>
</section>

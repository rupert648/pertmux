---
---
<section class="py-24 bg-gray-950 relative border-t border-gray-900">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Up and running in 60 seconds
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      
      <!-- Step 1 -->
      <div class="relative">
        <div class="absolute -left-4 top-0 flex h-8 w-8 items-center justify-center rounded-full bg-orange-500/20 border border-orange-500/50 text-orange-400 font-bold font-mono text-sm">1</div>
        <div class="pl-6">
          <h3 class="text-lg font-bold text-white mb-4">Install</h3>
          <div class="rounded-lg bg-gray-900 border border-gray-800 p-4 overflow-x-auto">
            <pre class="text-sm font-mono text-gray-300"><code><span class="text-orange-400">$</span> cargo install pertmux</code></pre>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative">
        <div class="absolute -left-4 top-0 flex h-8 w-8 items-center justify-center rounded-full bg-orange-500/20 border border-orange-500/50 text-orange-400 font-bold font-mono text-sm">2</div>
        <div class="pl-6">
          <h3 class="text-lg font-bold text-white mb-4">Configure</h3>
          <div class="rounded-lg bg-gray-900 border border-gray-800 p-4 overflow-x-auto">
            <pre class="text-sm font-mono text-gray-300"><code><span class="text-gray-500"># ~/.config/pertmux/pertmux.toml</span>
[[project]]
name = <span class="text-green-400">"My App"</span>
source = <span class="text-green-400">"github"</span>
local_path = <span class="text-green-400">"~/repos/my-app"</span></code></pre>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="relative">
        <div class="absolute -left-4 top-0 flex h-8 w-8 items-center justify-center rounded-full bg-orange-500/20 border border-orange-500/50 text-orange-400 font-bold font-mono text-sm">3</div>
        <div class="pl-6">
          <h3 class="text-lg font-bold text-white mb-4">Run</h3>
          <div class="rounded-lg bg-gray-900 border border-gray-800 p-4 overflow-x-auto">
            <pre class="text-sm font-mono text-gray-300"><code><span class="text-gray-500"># Start the background daemon</span>
<span class="text-orange-400">$</span> pertmux serve

<span class="text-gray-500"># Connect the TUI</span>
<span class="text-orange-400">$</span> pertmux connect</code></pre>
          </div>
        </div>
      </div>

    </div>

    <div class="mt-16 text-center">
      <a href="/getting-started/quick-start/" class="inline-flex items-center gap-2 text-orange-400 hover:text-orange-300 font-semibold transition-colors">
        Read the full guide <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

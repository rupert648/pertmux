---
---
<section class="py-24 bg-gray-950 relative overflow-hidden">
  <!-- Subtle grid background -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-50"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Every layer, linked automatically
      </h2>
      <p class="mt-4 text-lg text-gray-400">
        pertmux connects merge requests to branches, worktrees, tmux panes, and coding agents — so selecting an MR reveals your entire workflow context.
      </p>
    </div>

    <!-- Diagram -->
    <div class="flex flex-col lg:flex-row items-center justify-center gap-4 lg:gap-8 mb-20 overflow-x-auto pb-8">
      
      <!-- Node 1: MR -->
      <div class="flex flex-col items-center relative group">
        <div class="w-48 h-24 bg-gray-900 border border-orange-500/50 rounded-xl flex flex-col items-center justify-center shadow-[0_0_20px_rgba(255,140,0,0.15)] transition-transform group-hover:-translate-y-1">
          <div class="flex items-center gap-2 text-orange-400 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><path d="M13 6h3a2 2 0 0 1 2 2v7"></path><line x1="6" y1="9" x2="6" y2="21"></line></svg>
            <span class="font-mono font-bold">MR !142</span>
          </div>
          <span class="text-xs text-gray-400">GitLab / GitHub</span>
        </div>
        <!-- Arrow down for mobile -->
        <div class="lg:hidden h-8 w-px bg-gradient-to-b from-orange-500/50 to-gray-700 my-2"></div>
      </div>

      <!-- Arrow right for desktop -->
      <div class="hidden lg:flex items-center justify-center w-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>

      <!-- Node 2: Branch -->
      <div class="flex flex-col items-center relative group">
        <div class="w-48 h-24 bg-gray-900 border border-gray-800 rounded-xl flex flex-col items-center justify-center transition-transform group-hover:-translate-y-1 group-hover:border-gray-600">
          <div class="flex items-center gap-2 text-gray-200 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>
            <span class="font-mono font-medium">feat/auth</span>
          </div>
          <span class="text-xs text-gray-500">Local Branch</span>
        </div>
        <!-- Arrow down for mobile -->
        <div class="lg:hidden h-8 w-px bg-gray-700 my-2"></div>
      </div>

      <!-- Arrow right for desktop -->
      <div class="hidden lg:flex items-center justify-center w-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>

      <!-- Node 3: Worktree -->
      <div class="flex flex-col items-center relative group">
        <div class="w-48 h-24 bg-gray-900 border border-gray-800 rounded-xl flex flex-col items-center justify-center transition-transform group-hover:-translate-y-1 group-hover:border-gray-600">
          <div class="flex items-center gap-2 text-gray-200 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
            <span class="font-mono font-medium text-sm truncate max-w-[140px]">~/repos/wt/auth</span>
          </div>
          <span class="text-xs text-gray-500">Git Worktree</span>
        </div>
        <!-- Arrow down for mobile -->
        <div class="lg:hidden h-8 w-px bg-gray-700 my-2"></div>
      </div>

      <!-- Arrow right for desktop -->
      <div class="hidden lg:flex items-center justify-center w-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>

      <!-- Node 4: tmux -->
      <div class="flex flex-col items-center relative group">
        <div class="w-48 h-24 bg-gray-900 border border-gray-800 rounded-xl flex flex-col items-center justify-center transition-transform group-hover:-translate-y-1 group-hover:border-gray-600">
          <div class="flex items-center gap-2 text-gray-200 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
            <span class="font-mono font-medium">dev:2.1</span>
          </div>
          <span class="text-xs text-gray-500">tmux Pane</span>
        </div>
        <!-- Arrow down for mobile -->
        <div class="lg:hidden h-8 w-px bg-gray-700 my-2"></div>
      </div>

      <!-- Arrow right for desktop -->
      <div class="hidden lg:flex items-center justify-center w-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>

      <!-- Node 5: Agent -->
      <div class="flex flex-col items-center relative group">
        <div class="w-48 h-24 bg-gray-900 border border-orange-500/50 rounded-xl flex flex-col items-center justify-center shadow-[0_0_20px_rgba(255,140,0,0.15)] transition-transform group-hover:-translate-y-1">
          <div class="flex items-center gap-2 text-orange-400 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            <span class="font-mono font-bold flex items-center gap-1">
              <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
              Busy
            </span>
          </div>
          <span class="text-xs text-gray-400">Coding Agent</span>
        </div>
      </div>

    </div>

    <!-- Screenshot Placeholder -->
    <div class="flex justify-center">
      <div class="relative w-full max-w-[900px] aspect-video rounded-xl border border-gray-800 bg-gray-900/50 shadow-[0_0_40px_rgba(255,140,0,0.1)] flex items-center justify-center overflow-hidden backdrop-blur-sm">
        <!-- Window controls decoration -->
        <div class="absolute top-0 left-0 w-full h-10 border-b border-gray-800 bg-gray-900/80 flex items-center px-4 gap-2">
          <div class="w-3 h-3 rounded-full bg-gray-700"></div>
          <div class="w-3 h-3 rounded-full bg-gray-700"></div>
          <div class="w-3 h-3 rounded-full bg-gray-700"></div>
        </div>
        
        <p class="text-gray-500 italic font-mono text-sm sm:text-base mt-10">
          [ Screenshot placeholder: Linking in action ]
        </p>
      </div>
    </div>

  </div>
</section>

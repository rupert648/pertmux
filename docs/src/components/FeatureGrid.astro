---
---
<section class="py-24 bg-gray-900 relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Everything you need, in one terminal
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <!-- Feature 1 -->
      <div class="group relative rounded-2xl border border-gray-800 bg-gray-950 p-8 transition-all hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(255,140,0,0.1)]">
        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gray-900 border border-gray-800 text-orange-400 group-hover:bg-orange-500/10 group-hover:border-orange-500/30 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
        </div>
        <h3 class="mb-3 text-xl font-bold text-white">Multi-Forge</h3>
        <p class="text-gray-400 leading-relaxed">
          GitHub + GitLab behind one interface. Pipeline dots, comments, unread indicators.
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="group relative rounded-2xl border border-gray-800 bg-gray-950 p-8 transition-all hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(255,140,0,0.1)]">
        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gray-900 border border-gray-800 text-orange-400 group-hover:bg-orange-500/10 group-hover:border-orange-500/30 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>
        </div>
        <h3 class="mb-3 text-xl font-bold text-white">Worktree Management</h3>
        <p class="text-gray-400 leading-relaxed">
          Create, remove, merge worktrees without leaving the dashboard. Powered by worktrunk.
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="group relative rounded-2xl border border-gray-800 bg-gray-950 p-8 transition-all hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(255,140,0,0.1)]">
        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gray-900 border border-gray-800 text-orange-400 group-hover:bg-orange-500/10 group-hover:border-orange-500/30 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>
        </div>
        <h3 class="mb-3 text-xl font-bold text-white">Agent Monitoring</h3>
        <p class="text-gray-400 leading-relaxed">
          Track Claude and opencode instances across tmux panes. Status, tokens, todos.
        </p>
      </div>

      <!-- Feature 4 -->
      <div class="group relative rounded-2xl border border-gray-800 bg-gray-950 p-8 transition-all hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(255,140,0,0.1)]">
        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gray-900 border border-gray-800 text-orange-400 group-hover:bg-orange-500/10 group-hover:border-orange-500/30 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="2"></circle><circle cx="12" cy="12" r="2"></circle><circle cx="19" cy="12" r="2"></circle></svg>
        </div>
        <h3 class="mb-3 text-xl font-bold text-white">Pipeline Dots</h3>
        <p class="text-gray-400 leading-relaxed">
          Compact CI/CD visualization. Each job is a colored dot grouped by stage.
        </p>
      </div>

      <!-- Feature 5 -->
      <div class="group relative rounded-2xl border border-gray-800 bg-gray-950 p-8 transition-all hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(255,140,0,0.1)]">
        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gray-900 border border-gray-800 text-orange-400 group-hover:bg-orange-500/10 group-hover:border-orange-500/30 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
        </div>
        <h3 class="mb-3 text-xl font-bold text-white">Multi-Project</h3>
        <p class="text-gray-400 leading-relaxed">
          Fuzzy finder for instant project switching. Overview panel with MR counts.
        </p>
      </div>

      <!-- Feature 6 -->
      <div class="group relative rounded-2xl border border-gray-800 bg-gray-950 p-8 transition-all hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(255,140,0,0.1)]">
        <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gray-900 border border-gray-800 text-orange-400 group-hover:bg-orange-500/10 group-hover:border-orange-500/30 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
        </div>
        <h3 class="mb-3 text-xl font-bold text-white">Daemon Architecture</h3>
        <p class="text-gray-400 leading-relaxed">
          Background daemon keeps data fresh. TUI connects instantly via Unix socket.
        </p>
      </div>

    </div>
  </div>
</section>
